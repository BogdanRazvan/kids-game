    "record-weather": "node --experimental-strip-types scripts/record-set.mjs weather",
    "record-vehicles": "node --experimental-strip-types scripts/record-set.mjs vehicles",
    "record-jobs": "node --experimental-strip-types scripts/record-set.mjs jobs",
    "record-opposites": "node --experimental-strip-types scripts/record-set.mjs opposites",
