    "split-digits": "node --experimental-strip-types scripts/split-letters.mjs digits",
    "record-letters": "node --experimental-strip-types scripts/record-set.mjs letters",
    "record-digits": "node --experimental-strip-types scripts/record-set.mjs digits",
    "record-shapes": "node --experimental-strip-types scripts/record-set.mjs shapes",
